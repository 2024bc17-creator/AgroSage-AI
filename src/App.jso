          alignItems: "center",
          color: "white",
          position: "sticky",
          top: 0,
          zIndex: 1000,
          boxShadow: "0 4px 15px rgba(0,0,0,0.2)",
        }}
      >
        <h1 style={{ fontSize: "32px" }}>
          🌿 AgroSage AI
        </h1>

        <div style={{ display: "flex", gap: "20px" }}>
          <button
            style={navBtn}
            onClick={() => setPage("home")}
          >
            Home
          </button>

          <button
            style={navBtn}
            onClick={() => setPage("diseases")}
          >
            Diseases
          </button>

          <button
            style={navBtn}
            onClick={() => setPage("fertilizers")}
          >
            Fertilizers
          </button>

          <button
            style={navBtn}
            onClick={() => setPage("market")}
          >
            Market Prices
          </button>

          <button
            style={navBtn}
            onClick={() => setPage("contact")}
          >
            Contact
          </button>

          <button
            style={navBtn}
            onClick={() => setIsLoggedIn(false)}
          >
            Logout
          </button>
        </div>
      </div>

      {/* HOME */}
      {page === "home" && (
        <div>
          {/* HERO */}
          <div
            style={{
              position: "relative",
              height: "600px",
              overflow: "hidden",
            }}
          >
            <img
              src={sliderImages[currentSlide]}
              alt="slider"
              style={{
                width: "100%",
                height: "100%",
                objectFit: "cover",
              }}
            />

            <div
              style={{
                position: "absolute",
                inset: 0,
                background: "rgba(0,0,0,0.45)",
                display: "flex",
                flexDirection: "column",
                justifyContent: "center",
                alignItems: "center",
                color: "white",
                textAlign: "center",
              }}
            >
              <h1
                style={{
                  fontSize: "70px",
                  fontWeight: "bold",
                }}
              >
                Smart Farming Future
              </h1>

              <p
                style={{
                  fontSize: "24px",
                  marginTop: "15px",
                }}
              >
                AI Crop Disease Detection &
                Fertilizer Guidance
              </p>

              <button style={heroBtn}>
                Explore Now
              </button>
            </div>
          </div>

          {/* WEATHER */}
          <div
            style={{
              display: "grid",
              gridTemplateColumns:
                "repeat(auto-fit,minmax(250px,1fr))",
              gap: "25px",
              padding: "40px",
            }}
          >
            <div style={weatherCard}>
              <h2>☀️ Madurai</h2>
              <p>34°C Sunny</p>
            </div>

            <div style={weatherCard}>
              <h2>🌧 Chennai</h2>
              <p>29°C Rainy</p>
            </div>

            <div style={weatherCard}>
              <h2>☁️ Coimbatore</h2>
              <p>26°C Cloudy</p>
            </div>
          </div>

          {/* IMAGE UPLOAD */}
          <div style={sectionCard}>
            <h1 style={sectionTitle}>
              Upload Crop Image
            </h1>

            <input
              type="file"
              onChange={handleImageUpload}
            />

            {uploadedImage && (
              <img
                src={uploadedImage}
                alt="upload"
                style={{
                  width: "350px",
                  marginTop: "20px",
                  borderRadius: "20px",
                  boxShadow:
                    "0 5px 20px rgba(0,0,0,0.2)",
                }}
              />
            )}
          </div>

          {/* AI */}
          <div style={aiSection}>
            <h1 style={{ fontSize: "40px" }}>
              🤖 AI Crop Assistant
            </h1>

            <input
              placeholder="Ask about crops..."
              style={aiInput}
            />

            <button style={heroBtn}>
              Ask AI
            </button>
          </div>
        </div>
      )}

      {/* DISEASES */}
      {page === "diseases" && (
        <div style={{ padding: "40px" }}>
          <h1 style={pageTitle}>
            🦠 Crop Diseases
          </h1>

          <div style={gridStyle}>
            {diseaseData.map((item, index) => (
              <div key={index} style={card}>
                <img
                  src={item.image}
                  alt={item.name}
                  style={cardImage}
                />

                <h2 style={cardTitle}>
                  {item.name}
                </h2>

                <p style={{ padding: "0 20px 20px" }}>
                  Disease detection and crop protection
                  guidance.
                </p>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* FERTILIZERS */}
      {page === "fertilizers" && (
        <div style={{ padding: "40px" }}>
          <h1 style={pageTitle}>
            🌾 Fertilizers
          </h1>

          <div style={gridStyle}>
            {fertilizerData.map((item, index) => (
              <div key={index} style={card}>
                <img
                  src={item.image}
                  alt={item.name}
                  style={cardImage}
                />

                <h2 style={cardTitle}>
                  {item.name}
                </h2>

                <p style={{ padding: "0 20px 20px" }}>
                  Helps improve healthy crop growth.
                </p>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* MARKET */}
      {page === "market" && (
        <div style={{ padding: "40px" }}>
          <h1 style={pageTitle}>
            📈 Live Crop Market Prices
          </h1>

          <div style={gridStyle}>
            {marketPrices.map((item, index) => (
              <div key={index} style={card}>
                <img
                  src={item.image}
                  alt={item.crop}
                  style={cardImage}
                />

                <h2 style={cardTitle}>
                  {item.crop}
                </h2>

                <h3
                  style={{
                    color: "green",
                    padding: "0 20px 20px",
                  }}
                >
                  {item.price}
                </h3>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* CONTACT */}
      {page === "contact" && (
        <div style={{ padding: "50px" }}>
          <div style={contactBox}>
            <h1 style={pageTitle}>
              📞 Contact Us
            </h1>

            <input
              placeholder="Name"
              style={contactInput}
            />

            <input
              placeholder="Email"
              style={contactInput}
            />

            <textarea
              placeholder="Message"
              rows="5"
              style={contactInput}
            />

            <button style={heroBtn}>
              Submit
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

