  }

  // MAIN WEBSITE
  return (
    <div
      style={{
        minHeight: "100vh",
        background: "#f4fff4",
        fontFamily: "Arial",
      }}
    >
      {/* NAVBAR */}
      <div
        style={{
          background:
            "linear-gradient(90deg,#0f9b0f,#38ef7d)",
