  {
    crop: "Chilli",
    price: "₹5400 / Quintal",
    image:
      "https://images.unsplash.com/photo-1512621776951-a57141f2eefd",
  },
  {
    crop: "Groundnut",
    price: "₹6100 / Quintal",
    image:
      "https://images.unsplash.com/photo-1506806732259-39c2d0268443",
